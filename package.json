{
  "name": "finnance-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:update": "playwright test --update-snapshots",
    "check:dashboard-css": "node scripts/check-dashboard-css.mjs",
    "check:wallet-panel-css": "node scripts/check-wallet-panel-css.mjs",
    "check:vertical-kpi-css": "node scripts/check-vertical-kpi-css.mjs",
    "lint:css": "stylelint \"app/**/*.css\"",
    "lint:css:fix": "stylelint \"app/**/*.css\" --fix",
    "lint:layout": "node scripts/lint-layout.mjs",
    "lint:frontend": "npm run lint:css && npm run lint:layout && npm run check:wallet-panel-css && npm run check:vertical-kpi-css"
  },
  "dependencies": {
    "@visx/axis": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "d3-array": "^3.2.4",
    "d3-format": "^3.1.2",
    "d3-time-format": "^4.1.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^39.0.0",
    "typescript": "^5.0.0"
  }
}
